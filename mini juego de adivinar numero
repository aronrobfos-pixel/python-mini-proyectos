import random
numsecreto = random.randint(1,100)
intentos = 2

while intentos > 0:
    numusuario = int(input("pone un numero: "))
    if numusuario == numsecreto:
        print("GANASTE")
        break
    else:
        if numsecreto < numusuario:
            print("MENOOOS")
            intentos -=1
            print("quedan", intentos, "intentos")
        else:
            print("MAAASSS")
            intentos -=1
            print("quedan", intentos, "intentos")
    if intentos == 0:
        print("PERDISTE")